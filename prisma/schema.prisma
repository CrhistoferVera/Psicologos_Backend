generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          String                    @id @default(uuid())
  phoneNumber                 String                    @unique
  email                       String?                   @unique
  referralCode                String?                   @unique
  password                    String?
  firstName                   String?
  lastName                    String?
  fcmToken                    String?
  isProfileComplete           Boolean                   @default(false)
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  lastLogin                   DateTime?
  role                        UserRole                  @default(USER)
  resetPasswordExpiry         DateTime?
  resetPasswordToken          String?
  isActive                    Boolean                   @default(true)

  anfitrionaProfile           AnfitrioneProfile?
  userProfile                 UserProfile?
  wallet                      Wallet?
  depositRequests             DepositRequest[]
  conversationsAsUser1        Conversation[]            @relation("ConversationUser1")
  conversationsAsUser2        Conversation[]            @relation("ConversationUser2")
  sentMessages                Message[]                 @relation("SentMessages")
  professionalSpecialties     ProfessionalSpecialty[]
  promotionalCreditsGranted   PromotionalCreditGrant[]  @relation("PromotionalCreditsGrantedBy")
  promotionalCreditsReceived  PromotionalCreditGrant[]  @relation("PromotionalCreditsReceivedBy")
  referralsSent               Referral[]                @relation("ReferralReferrer")
  referralAsReferred          Referral?                 @relation("ReferralReferred")

  @@map("users")
}

model UserProfile {
  id             String    @id @default(uuid())
  userId         String    @unique
  userName       String?
  bio            String?   @db.Text
  avatarUrl      String?
  avatarPublicId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile")
}

model Conversation {
  id             String    @id @default(uuid())
  user1Id        String
  user2Id        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user1          User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2          User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  read           Boolean       @default(false)
  createdAt      DateTime      @default(now())

  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User          @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

model AnfitrioneProfile {
  id             String            @id @default(uuid())
  userId         String            @unique
  username       String            @unique
  dateOfBirth    DateTime?
  cedula         String?           @unique
  idDocUrl       String?
  idDocPublicId  String?
  avatarUrl      String?
  avatarPublicId String?
  bio            String?
  rateCredits    Int?
  isOnline       Boolean           @default(false)
  coverPublicId  String?
  coverUrl       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts   BankAccount[]
  servicePrices  ServicePrice[]

  @@map("anfitrione_profiles")
}

model Wallet {
  id                 String              @id @default(uuid())
  userId             String              @unique
  balance            Decimal             @default(0.00) @db.Decimal(10, 2)
  promotionalBalance Decimal             @default(0.00) @db.Decimal(10, 2)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  withdrawalRequests WithdrawalRequest[]

  @@map("wallets")
}

model Package {
  id               String            @id @default(uuid())
  name             String            @db.VarChar(100)
  credits          Int
  price            Decimal           @db.Decimal(10, 2)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  depositRequests  DepositRequest[]

  @@map("packages")
}

model DepositRequest {
  id                  String          @id @default(uuid())
  userId              String
  packageId           String?
  paymentMethodId     String?
  amount              Decimal         @db.Decimal(10, 2)
  receiptUrl          String
  receiptPublicId     String?
  status              DepositStatus   @default(PENDING)
  rejectionReason     String?
  creditsToDeliver    Int             @default(0)
  packageNameAtMoment String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  package             Package?        @relation(fields: [packageId], references: [id])
  paymentMethod       PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  transaction         Transaction?
  qualifyingReferral  Referral?

  @@map("deposit_requests")
}

model PaymentMethod {
  id              String            @id @default(uuid())
  type            PaymentType
  bankName        String?
  accountName     String?
  accountNumber   String?
  qrImageUrl      String?
  qrPublicId      String?
  logoPublicId    String?
  logoUrl         String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  depositRequests DepositRequest[]

  @@map("payment_methods")
}

model Transaction {
  id                     String                  @id @default(uuid())
  walletId               String
  depositRequestId       String?                 @unique
  type                   TransactionType
  amount                 Decimal                 @db.Decimal(10, 2)
  promotionalAmount      Decimal                 @default(0.00) @db.Decimal(10, 2)
  realAmount             Decimal                 @default(0.00) @db.Decimal(10, 2)
  isPromotional          Boolean                 @default(false)
  description            String?
  createdAt              DateTime                @default(now())

  wallet                 Wallet                  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  depositRequest         DepositRequest?         @relation(fields: [depositRequestId], references: [id])
  promotionalCreditGrant PromotionalCreditGrant?
  referralReward         Referral?

  @@index([walletId, createdAt])
  @@index([type, createdAt])
  @@map("transactions")
}

model ServicePrice {
  id             String            @id @default(uuid())
  profileId      String
  serviceType    ServiceType
  price          Float
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  profile        AnfitrioneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, serviceType])
  @@map("service_prices")
}

model Banks {
  id             Int               @id @default(autoincrement())
  name           String
  logo_url       String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime?         @updatedAt

  bankAccounts   BankAccount[]
}

model BankAccount {
  id                  BigInt              @id @default(autoincrement())
  userId              String
  bankId              Int
  anfitrionaProfileId String
  accountNumber       String              @db.VarChar(50)
  accountHolderName   String?             @db.VarChar(100)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime?           @updatedAt

  bank                Banks               @relation(fields: [bankId], references: [id])
  anfitrionaProfile   AnfitrioneProfile   @relation(fields: [anfitrionaProfileId], references: [id], onDelete: Cascade)
  withdrawalRequests  WithdrawalRequest[]

  @@index([userId])
  @@index([bankId])
  @@index([accountNumber])
  @@map("bank_accounts")
}

model WithdrawalRequest {
  id               String            @id @default(uuid())
  walletId         String
  bankAccountId    BigInt
  credits          Decimal           @db.Decimal(10, 2)
  soles            Decimal           @db.Decimal(10, 2)
  status           WithdrawalStatus  @default(PENDING)
  notes            String?
  rejectionReason  String?
  receiptUrl       String?
  receiptPublicId  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  wallet           Wallet            @relation(fields: [walletId], references: [id])
  bankAccount      BankAccount       @relation(fields: [bankAccountId], references: [id])

  @@map("withdrawal_requests")
}

model Specialty {
  id             String                  @id @default(uuid())
  name           String                  @unique
  slug           String                  @unique
  description    String?
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  professionals  ProfessionalSpecialty[]

  @@map("specialties")
}

model ProfessionalSpecialty {
  id             String     @id @default(uuid())
  professionalId String
  specialtyId    String
  createdAt      DateTime   @default(now())

  professional   User       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  specialty      Specialty  @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([professionalId, specialtyId])
  @@index([specialtyId])
  @@map("professional_specialties")
}

model PromotionalCreditGrant {
  id               String       @id @default(uuid())
  adminUserId      String
  recipientUserId  String
  transactionId    String       @unique
  amount           Decimal      @db.Decimal(10, 2)
  reason           String?
  createdAt        DateTime     @default(now())

  adminUser        User         @relation("PromotionalCreditsGrantedBy", fields: [adminUserId], references: [id], onDelete: Cascade)
  recipientUser    User         @relation("PromotionalCreditsReceivedBy", fields: [recipientUserId], references: [id], onDelete: Cascade)
  transaction      Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([recipientUserId])
  @@index([adminUserId])
  @@map("promotional_credit_grants")
}

model Referral {
  id                       String          @id @default(uuid())
  referrerUserId           String
  referredUserId           String          @unique
  codeUsed                 String
  status                   ReferralStatus  @default(PENDING)
  referredDepositRequestId String?         @unique
  rewardTransactionId      String?         @unique
  rewardCredits            Decimal         @default(0.00) @db.Decimal(10, 2)
  qualifiedAt              DateTime?
  rewardedAt               DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  referrer                 User            @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred                 User            @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  referredDepositRequest   DepositRequest? @relation(fields: [referredDepositRequestId], references: [id], onDelete: SetNull)
  rewardTransaction        Transaction?    @relation(fields: [rewardTransactionId], references: [id], onDelete: SetNull)

  @@index([referrerUserId])
  @@index([status, createdAt])
  @@map("referrals")
}

model SystemConfig {
  id                       String   @id @default("global")
  platformFeePercent       Decimal  @default(50.00) @db.Decimal(5, 2)
  creditToSolesRate        Decimal  @default(1.00) @db.Decimal(10, 2)
  minAppVersion            String   @default("1.0")
  referralRewardCredits    Decimal  @default(10.00) @db.Decimal(10, 2)
  referralMinDepositAmount Decimal  @default(0.00) @db.Decimal(10, 2)
  referralEnabled          Boolean  @default(true)
  paymentsEnabled          Boolean  @default(true)
  withdrawalsEnabled       Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("system_config")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  MESSAGE_SEND
  CALL_PAYMENT
  EARNING
  PROMOTIONAL_GRANT
  REFERRAL_REWARD
}

enum ServiceType {
  MESSAGE_SEND
  CALL
  VIDEO_CALL
}

enum PaymentType {
  QR
  TRANSFERENCIA
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
  ANFITRIONA
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
}
